# Ghostty Configuration — Thin terminal, Zellij handles multiplexing
# Reload with Cmd+Shift+,

# Theme
theme = ayu-dark

# Font
font-family = IosevkaTerm Nerd Font
font-family = Symbols Nerd Font Mono
font-size = 14

# Appearance
background-opacity = 0.80
background-blur = 20
window-theme = dark
macos-titlebar-style = hidden

# Auto-launch Zellij — always reconnect to the same named session.
# `attach --create main` attaches if "main" is running, resurrects it (restoring
# tabs/panes/layout) if it EXITED, or creates it if it doesn't exist yet. Using a
# fixed name avoids the random-named session pile-up that bare `--create` caused.
command = /opt/homebrew/bin/zellij attach --create main

# Shell integration (works inside Zellij-spawned shells)
shell-integration = zsh

# Clipboard
clipboard-read = allow
clipboard-write = allow

# Keybindings — clear all, re-add only macOS essentials
# Everything else passes through to Zellij
keybind = clear
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+shift+comma=reload_config
keybind = super+q=quit
keybind = super+n=unbind

# Clicking links inside Zellij
# -----------------------------
# Zellij runs with `mouse_mode true`, so it captures the mouse and Ghostty's
# native super+click-to-open-link never fires. Two ways to reach a link:
#
#   1. Hold Shift and click the link (super+shift+click to open it). Shift
#      bypasses Zellij's mouse capture so Ghostty handles the click — links
#      open, drag selects. `never` (vs the default `false`) stops Zellij from
#      reclaiming Shift via XTSHIFTESCAPE, so this always works.
#   2. super+shift+m toggles mouse reporting OFF entirely: every link becomes a
#      plain Ghostty click again. Toggle back on to restore Zellij's
#      focus-follows-mouse / copy-on-select / pane clicks.
mouse-shift-capture = never
keybind = super+shift+m=toggle_mouse_reporting
