{
  // Default Claude Code profile: claude-code-base + egress filtering.
  // network_profile is the real containment (see ../README.md); allow_domain widens
  // the proxy allowlist for hosts the claude-code network policy does not cover.
  "extends": [
    "claude-code-base"
  ],
  "meta": {
    "name": "",
    "version": "",
    "description": "Claude Code sandbox with egress filtering",
    "author": null
  },
  "network": {
    "network_profile": "claude-code",
    "allow_domain": [
      "api.supabase.com",
      "mcp.supabase.com",
      "registry.nono.sh",
      "nono.sh"
    ]
  }
}
