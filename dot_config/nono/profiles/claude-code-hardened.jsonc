{
  "extends": [
    "claude-code"
  ],
  "meta": {
    "name": "",
    "version": "",
    "description": null,
    "author": null
  },
  "security": {
    "signal_mode": null,
    "process_info_mode": null,
    "ipc_mode": null,
    "capability_elevation": null,
    "wsl2_proxy_policy": null
  },
  "groups": {
    "include": [],
    "exclude": []
  },
  "commands": {
    "allow": [],
    "deny": []
  },
  "filesystem": {
    "allow": [
      "$HOME/.npm",
      "$HOME/.nono-share"
    ],
    "read": [
      "$HOME/.local/share/mise",
      "$HOME/.config/gh",
      "$HOME/.config/glab-cli",
      "~/.agents/skills"
    ],
    "write": [
      "$HOME/workspace"
    ],
    "allow_file": [],
    "read_file": [
      "$HOME/.gitconfig.local"
    ],
    "write_file": [],
    "unix_socket": [],
    "unix_socket_bind": [],
    "unix_socket_dir": [],
    "unix_socket_dir_bind": [],
    "unix_socket_subtree": [],
    "unix_socket_subtree_bind": [],
    "deny": [],
    "bypass_protection": [],
    "suppress_save_prompt": [
      "~/"
    ]
  },
  "network": {
    "block": false,
    "allow_http2": false,
    "network_profile": "claude-code",
    "allow_domain": [
      "api.supabase.com",
      "mcp.supabase.com"
    ],
    "open_port": [
      9222,
      5037
    ],
    "listen_port": [],
    "connect_port": [],
    "custom_credentials": {},
    "tls_intercept": null,
    "upstream_proxy": null,
    "upstream_bypass": []
  },
  "diagnostics": {
    "suppress_system_services": []
  },
  "linux": {
    "af_unix_mediation": null,
    "sandbox_policy": null
  },
  "env_credentials": {},
  "environment": {
    "set_vars": {
      "HERDR_CLAUDE_LIFECYCLE": "1"
    }
  },
  "command_policies": {},
  "credential_capture": {},
  "credential_providers": {},
  "credential_routes": [],
  "workdir": {
    "access": "none"
  },
  "hooks": {},
  "session_hooks": {},
  "rollback": {
    "exclude_patterns": [],
    "exclude_globs": []
  },
  "open_urls": {
    "allow_origins": [
      "https://api.supabase.com"
    ]
  },
  "allow_launch_services": null,
  "allow_gpu": null,
  "allow_parent_of_protected": null,
  "interactive": false,
  "skipdirs": [],
  "packs": [],
  "binary": null,
  "command_args": [],
  "unsafe_macos_seatbelt_rules": []
}
