# shellcheck disable=all

# zmodload zsh/zprof

XDG_CONFIG_HOME="$HOME/.config"
XDG_DATA_HOME="$HOME/.local/share"
XDG_CACHE_HOME="$HOME/.cache"

# Base PATH: personal bin dirs + dedupe. Set early so the homebrew plugin and mise
# (loaded later) prepend themselves in front — stable order, no bottom-of-file race.
# typeset -U keeps the first occurrence of each entry (no duplicates).
typeset -U path PATH
path=("$HOME/.local/bin" "$HOME/go/bin" $path)

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

function is-macos() {
    [[ $OSTYPE == darwin* ]]
}

EDITOR="vim"
VISUAL="vim"

# Set editor default keymap to emacs (`-e`) or vi (`-v`)
bindkey -e

# Prompt for spelling correction of commands.
setopt CORRECT

# Customize spelling correction prompt.
SPROMPT='zsh: correct %F{red}%R%f to %F{green}%r%f [nyae]? '

# Remove / and - from WORDCHARS.
WORDCHARS=${WORDCHARS//[\/-]/}

# Disable automatic widget re-binding on each precmd.
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# Customize the style that the suggestions are shown with.
# See https://github.com/zsh-users/zsh-autosuggestions/blob/master/README.md#suggestion-highlight-style
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=242'

# Set what highlighters will be used.
# See https://github.com/zsh-users/zsh-syntax-highlighting/blob/master/docs/highlighters.md
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)

# Customize the main highlighter styles.
# See https://github.com/zsh-users/zsh-syntax-highlighting/blob/master/docs/highlighters/main.md#how-to-tweak-it
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[comment]='fg=242'

# Load $terminfo so the binds below can reference ${terminfo[kcuu1/kcud1]} (ghostty's
# app-mode ^[OA/^[OB up/down codes). p10k's instant prompt usually loads it first; this
# makes the bindings self-sufficient if that cache is ever missing. -F +p:terminfo
# loads only the $terminfo parameter feature.
zmodload -F zsh/terminfo +p:terminfo

# Bind ^[[A/^[[B manually so up/down works both before and after zle-line-init
for key in '^[[A' '^P' ${terminfo[kcuu1]}; do
    bindkey "$key" history-substring-search-up
done
for key in '^[[B' '^N' ${terminfo[kcud1]}; do
    bindkey "$key" history-substring-search-down
done
bindkey -M vicmd 'k' history-substring-search-up
bindkey -M vicmd 'j' history-substring-search-down
unset key

# Bind Alt+←/→ to word motion. Option+arrow reaches zsh as ^[[1;3D / ^[[1;3C
# (ghostty emits the Alt modifier for arrows even with macos-option-as-alt
# unset), but zsh leaves those undefined-key by default. Alt+h/l left alone.
bindkey '^[[1;3D' backward-word # Alt+Left  → previous word
bindkey '^[[1;3C' forward-word  # Alt+Right → next word

# Enable bash completion compatibility.
# After this, you can use complete -F and other bash completion commands in zsh,
# which is useful for tools that only provide bash completion scripts (like terraform, kubectl, etc).
autoload -U +X bashcompinit && bashcompinit

zstyle ':zephyr:plugin:history' 'histfile' "$HOME/.zsh_history"
zstyle ':zephyr:plugin:history:aux:sqlite' enable yes
zstyle ':zephyr:plugin:history:aux:json' enable yes

# Globbing
unsetopt CASE_GLOB   # Case-insensitive globbing
setopt EXTENDED_GLOB # Advanced globbing (**, ^, ~, etc.)
unsetopt GLOB_DOTS   # If enabled, globs match dotfiles - be careful with rm *
setopt NO_NOMATCH    # Pass through unmatched globs instead of error

setopt NO_LIST_BEEP # No beep on completion list

# Completion is owned by zephyr's `completion` plugin.
zstyle ':zephyr:plugin:completion' 'compstyle' 'zephyr'
zstyle ':zephyr:plugin:completion' 'use-cache' 'yes'

# zstyle ':completion:::::' completer _extensions _complete _approximate

# Complete the alias when _expand_alias is used as a function
zle -C alias-expansion complete-word _generic
bindkey '^xa' alias-expansion
zstyle ':completion:alias-expansion:*' completer _expand_alias

# Autocomplete options for cd instead of directory stack
zstyle ':completion:*' complete-options true
zstyle ':completion:*' file-sort modification

zstyle ':completion:*:*:*:*:corrections' format '%F{yellow}!- %d (errors: %e) -!%f'
zstyle ':completion:*:*:*:*:descriptions' format '%F{blue}-- %D %d --%f'
zstyle ':completion:*:*:*:*:messages' format ' %F{purple} -- %d --%f'
zstyle ':completion:*:*:*:*:warnings' format ' %F{red}-- no matches found --%f'
#zstyle ':completion:*:default' list-prompt '%S%M matches%s'

zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' keep-prefix true
zstyle -e ':completion:*:(ssh|scp|sftp|rsh|rsync):hosts' hosts 'reply=(${=${${(f)"$(cat {/etc/ssh_,~/.ssh/known_}hosts(|2)(N) /dev/null)"}%%[# ]*}//,/ })'
zstyle ':completion:*:*:-command-:*:*' group-order aliases builtins functions commands

# Bind edit-command-line to Ctrl+X, then Ctrl+E (standard for editing the command line in $EDITOR)
autoload -U edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line

# BEGIN Antidote setup

# Set the root name of the plugins files (.txt and .zsh) antidote will use.
zsh_plugins=${ZDOTDIR:-$HOME}/.zsh_plugins

# Ensure the .zsh_plugins.txt file exists so you can add plugins.
[[ -f ${zsh_plugins}.txt ]] || touch ${zsh_plugins}.txt

# Lazy-load antidote from its functions directory.
fpath=(~/.antidote/functions $fpath)
autoload -Uz antidote

# Generate a new static file whenever .zsh_plugins.txt is updated.
if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]]; then
    antidote bundle <${zsh_plugins}.txt >|${zsh_plugins}.zsh
fi

# Source your static plugins file.
source ${zsh_plugins}.zsh

# END Antidote setup

# Re-apply PATH_DIRS=off as zephyr's completion plugin sets `path_dirs`.
# security behavior of not searching $PATH for slashed command names.
unsetopt PATH_DIRS

# Load all files from zshrc.d directory
if [ -d "$HOME/.zsh.d" ]; then
    for file in "$HOME/.zsh.d"/*.zsh(N); do
        source "$file"
    done
fi

# Prime direnv for the starting directory silently (stderr suppressed) so its
# precmd hook has nothing left to log on the first prompt. This avoids p10k's
# "console output during zsh initialization" warning. Interactive `cd` into
# other directories still shows direnv's normal loading messages.
(($+commands[direnv])) && eval "$(direnv export zsh 2>/dev/null)"

# compinit is deferred to the first precmd, so register bash-style `complete -C`
# completions from a one-shot precmd hook (runs after compinit). Inline here they
# would run before compinit and be silently dropped. Each tool is guarded
# independently so one missing binary doesn't disable the others.
autoload -Uz add-zsh-hook
_register_bashcompl() {
    (($+commands[tk])) && complete -o nospace -C "$(command -v tk)" tk
    (($+commands[terraform])) && complete -o nospace -C "$(command -v terraform)" terraform
    add-zsh-hook -d precmd _register_bashcompl
}
add-zsh-hook precmd _register_bashcompl

autoload -Uz promptinit && promptinit && prompt powerlevel10k

export TG_PROVIDER_CACHE=1
export CLAUDE_CONFIG_DIR="$HOME/.claude"

nono-claude() {
  # herdr detection under nono needs BOTH (neither works alone under the inner
  # pty): HERDR_AGENT=claude so herdr trusts the pane is claude and does not
  # override with process detection, AND the report_agent hook
  # (~/.claude/hooks/herdr-nono-lifecycle.sh) which supplies presence+state over
  # herdr's socket -- hence the socket grant. The stock claude session hook is
  # suppressed for nono (settings.json) so its agent_session does not interfere.
  local -a herdr_grant
  [[ -n "$HERDR_SOCKET_PATH" ]] && herdr_grant=(--allow-unix-socket "$HERDR_SOCKET_PATH")
  HERDR_AGENT=claude nono run --allow-cwd --trust-proxy-ca \
    --allow-unix-socket "$SSH_AUTH_SOCK" \
    "${herdr_grant[@]}" \
    --profile claude-code-hardened -- claude --dangerously-skip-permissions "$@"
}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

